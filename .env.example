# ===== AI生图（豆包）=====
# 申请：https://console.volcengine.com/ark → API Keys
ARK_API_KEY=your_ark_api_key_here

# ===== 安全 =====
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ===== 支付宝网页支付 =====
# 申请：https://open.alipay.com
ALIPAY_APP_ID=2021006147626992
ALIPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ALIPAY_PRIVATE_KEY_PATH=./backend/secrets/app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=./backend/secrets/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://interior-ai-aemn.onrender.com/api/payment/callback/alipay

# ===== 域名 =====
DOMAIN=interior-ai-aemn.onrender.com
PUBLIC_SITE_URL=https://interior-ai-aemn.onrender.com
NEXT_PUBLIC_BASE_URL=https://interior-ai-aemn.onrender.com

